#include <Trade\Trade.mqh>

//--- User Inputs
input int      FastEMA          = 9;       
input int      SlowEMA          = 21;      
input int      ADX_Period       = 14;      // Trend Strength Period
input int      ADX_Min_Level    = 25;      // Filter: Only trade if ADX > 25
input int      ATR_Period       = 14;      // ATR Period for the Runner Trail
input double   ATR_Multiplier   = 1.5;     // ATR Multiplier for the Runner Trail
input double   Lots             = 0.5;     
input double   PartialClosePct  = 75.0;    
input int      StopLossPips     = 15;      // RESTORED: Original Fixed SL
input int      TakeProfitPips   = 20;      // RESTORED: Original Fixed TP
input int      BEPlusPips       = 2;       
input ulong    Magic            = 123456;  

//--- Globals
int            handle9EMA, handle21EMA, handleATR, handleADX;
CTrade         trade;
datetime       lastBarTime;

int OnInit()
{
   handle9EMA  = iMA(_Symbol, _Period, FastEMA, 0, MODE_EMA, PRICE_CLOSE);
   handle21EMA = iMA(_Symbol, _Period, SlowEMA, 0, MODE_EMA, PRICE_CLOSE);
   handleATR   = iATR(_Symbol, _Period, ATR_Period);
   handleADX   = iADX(_Symbol, _Period, ADX_Period);
   
   if(handle9EMA == INVALID_HANDLE || handle21EMA == INVALID_HANDLE || 
      handleATR == INVALID_HANDLE || handleADX == INVALID_HANDLE) 
      return(INIT_FAILED);

   trade.SetExpertMagicNumber(Magic);
   return(INIT_SUCCEEDED);
}

void OnTick()
{
   ManageRiskAndTrail();

   datetime currentBarTime = iTime(_Symbol, _Period, 0);
   if(currentBarTime == lastBarTime) return; 
   lastBarTime = currentBarTime;

   double v9[], v21[], adx[];
   ArraySetAsSeries(v9, true); ArraySetAsSeries(v21, true); ArraySetAsSeries(adx, true);

   if(CopyBuffer(handle9EMA, 0, 0, 3, v9) < 3) return;
   if(CopyBuffer(handle21EMA, 0, 0, 3, v21) < 3) return;
   if(CopyBuffer(handleADX, 0, 0, 1, adx) < 1) return;

   //--- MARKET REGIME FILTER ---
   // If ADX is low, we don't look for EMA crosses.
   if(adx[0] < ADX_Min_Level) return; 

   bool buySignal  = (v9[1] > v21[1]) && (v9[2] <= v21[2]);
   bool sellSignal = (v9[1] < v21[1]) && (v9[2] >= v21[2]);

   double pips = (_Digits == 3 || _Digits == 5) ? _Point * 10 : _Point;

   if(buySignal && !PositionSelect(_Symbol))
   {
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double sl  = ask - (StopLossPips * pips);
      trade.Buy(Lots, _Symbol, ask, sl, 0, "Classic Buy");
   }

   if(sellSignal && !PositionSelect(_Symbol))
   {
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double sl  = bid + (StopLossPips * pips);
      trade.Sell(Lots, _Symbol, bid, sl, 0, "Classic Sell");
   }
}

void ManageRiskAndTrail()
{
   double pips = (_Digits == 3 || _Digits == 5) ? _Point * 10 : _Point;
   double slDist = StopLossPips * pips;
   double tpDist = TakeProfitPips * pips;
   double plusDist = BEPlusPips * pips;
   
   double atrValue[];
   if(CopyBuffer(handleATR, 0, 0, 1, atrValue) < 1) return;
   double trailingBuffer = atrValue[0] * ATR_Multiplier;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol || PositionGetInteger(POSITION_MAGIC) != Magic) continue;

      double entryPrice = PositionGetDouble(POSITION_PRICE_OPEN);
      double currentSL  = PositionGetDouble(POSITION_SL);
      double currentVol = PositionGetDouble(POSITION_VOLUME);
      long   posType    = PositionGetInteger(POSITION_TYPE);
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

      // --- BUY POSITIONS ---
      if(posType == POSITION_TYPE_BUY)
      {
         double targetBE = entryPrice + slDist;
         double targetPartial = entryPrice + tpDist;
         double bePlusLevel = entryPrice + plusDist;

         if(bid >= targetBE && currentSL < (bePlusLevel - 0.00001))
            trade.PositionModify(ticket, bePlusLevel, 0);

         if(bid >= targetPartial && currentVol >= (Lots - 0.0001))
         {
            double closeVol = CalculatePartialLot(currentVol);
            if(trade.PositionClosePartial(ticket, closeVol))
               trade.PositionModify(ticket, targetBE, 0); 
         }

         if(currentVol < (Lots - 0.0001))
         {
            double newSL = bid - trailingBuffer;
            if(newSL > currentSL + (2 * _Point)) trade.PositionModify(ticket, newSL, 0);
         }
      }

      // --- SELL POSITIONS ---
      else if(posType == POSITION_TYPE_SELL)
      {
         double targetBE = entryPrice - slDist;
         double targetPartial = entryPrice - tpDist;
         double bePlusLevel = entryPrice - plusDist;

         if(ask <= targetBE && (currentSL > (bePlusLevel + 0.00001) || currentSL == 0))
            trade.PositionModify(ticket, bePlusLevel, 0);

         if(ask <= targetPartial && currentVol >= (Lots - 0.0001))
         {
            double closeVol = CalculatePartialLot(currentVol);
            if(trade.PositionClosePartial(ticket, closeVol))
               trade.PositionModify(ticket, targetBE, 0); 
         }

         if(currentVol < (Lots - 0.0001))
         {
            double newSL = ask + trailingBuffer;
            if(currentSL == 0 || newSL < currentSL - (2 * _Point)) trade.PositionModify(ticket, newSL, 0);
         }
      }
   }
}

double CalculatePartialLot(double currentVolume)
{
   double targetVol = currentVolume * (PartialClosePct / 100.0);
   double volStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   double minVol = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double roundedVol = MathFloor(targetVol / volStep) * volStep;
   return (roundedVol < minVol) ? minVol : roundedVol;
}
